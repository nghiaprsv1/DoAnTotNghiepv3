<mxfile host="app.diagrams.net"><diagram name="Luồng chat AI (công cụ và thuật toán)" id="cf"><mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="560" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ttl" value="TripMate — Luồng hỏi đáp trợ lý AI (công cụ và thuật toán)" style="text;html=1;align=center;fontStyle=1;fontSize=15;fontColor=#ab2d00;" vertex="1" parent="1"><mxGeometry x="0" y="30" width="1240" height="30" as="geometry"/></mxCell><mxCell id="agentbox" value="Trợ lý RAG v2 — LLM điều phối công cụ (function calling)" style="rounded=16;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#7A4FB0;strokeWidth=2;fontColor=#553089;fontStyle=1;fontSize=13;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="470" y="80" width="720" height="300" as="geometry"/></mxCell><mxCell id="user" value="Người dùng&#10;(đặt câu hỏi)" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#FFE3D2;strokeColor=#ab2d00;fontColor=#7a2000;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="40" y="110" width="160" height="66" as="geometry"/></mxCell><mxCell id="bubble" value="Bong bóng chat AI&#10;(AIChatBubble)" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#FFF1E8;strokeColor=#C0612F;fontColor=#8a3d12;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="250" y="110" width="180" height="66" as="geometry"/></mxCell><mxCell id="llm" value="Gemini LLM&#10;(điều phối · sinh câu trả lời)" style="rounded=12;whiteSpace=wrap;html=1;fillColor=#F3EAFF;strokeColor=#7A4FB0;fontColor=#553089;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="760" y="118" width="220" height="64" as="geometry"/></mxCell><mxCell id="toolDB" value="Tìm kiếm DB&#10;chuyến · địa điểm · HDV · bài viết" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#E9F7EF;strokeColor=#3E8E5E;fontColor=#2c6444