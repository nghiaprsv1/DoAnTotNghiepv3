# Development environment variables
# Copy this file to .env.local and fill in the values

VITE_APP_TITLE=TripMate
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_ENV=development

# Google Maps Embed API key — used by the TripMap panel.
# Get one at https://console.cloud.google.com/ (enable "Maps Embed API").
VITE_GOOGLE_MAPS_API_KEY=

# SePay (payment) — optional, only for showing the QR / bank info on the FE.
VITE_SEPAY_BANK_ACCOUNT=
VITE_SEPAY_BANK_NAME=
VITE_SEPAY_ACCOUNT_HOLDER=
