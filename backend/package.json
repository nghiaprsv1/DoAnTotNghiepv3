{
  "name": "tripmate-backend",
  "version": "0.1.0",
  "description": "TripMate — TravelSocial backend (NestJS + PostgreSQL)",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/datasource.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/datasource.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/datasource.ts",
    "schema:sync": "npm run typeorm -- schema:sync -d src/datasource.ts",
    "seed": "ts-node -r tsconfig-paths/register src/seed.ts",
    "seed:guides": "ts-node -r tsconfig-paths/register src/seed-guides.ts",
    "seed:trips": "ts-node -r tsconfig-paths/register src/seed-trips.ts",
    "seed:ai-trips": "ts-node -r tsconfig-paths/register src/seed-ai-trips.ts",
    "seed:provinces": "ts-node -r tsconfig-paths/register src/seed-provinces.ts",
    "rag:ingest": "ts-node -r tsconfig-paths/register src/rag-ingest.script.ts",
    "model:download": "node scripts/download-model.cjs",
    "rerank:download": "node scripts/download-reranker.cjs"
  },
  "dependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.6",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.22",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.21",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@xenova/transformers": "^2.17.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.4.5",
    "firebase-admin": "^14.0.0",
    "node-llama-cpp": "^3.18.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.20",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3"
  }
}
