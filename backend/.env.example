# Server
PORT=8080
NODE_ENV=development
APP_NAME=TripMate

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=tripmate
DB_SYNCHRONIZE=true
DB_LOGGING=false
# Bật SSL khi dùng Postgres managed trên cloud (Render/Neon/Supabase). Local để false.
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-but-different
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Email / SMTP (xác thực email khi đăng ký)
# Gmail: bật 2FA rồi tạo "App Password" (16 ký tự) tại https://myaccount.google.com/apppasswords
# Để trống cả 3 dòng host/user/pass → mã OTP sẽ in ra console backend (chế độ dev, không gửi mail thật).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Tên người gửi hiển thị (mặc định: TripMate <SMTP_USER>)
SMTP_FROM=TripMate <no-reply@tripmate.local>

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Upload (local fallback when no cloud storage is configured)
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE_MB=10

# ── Cloudinary (KHUYẾN NGHỊ — miễn phí, không cần thẻ tín dụng) ──
# Ưu tiên cao nhất khi upload ảnh. Cung cấp MỘT trong hai:
#   CLOUDINARY_URL = cloudinary://<api_key>:<api_secret>@<cloud_name>
#   HOẶC 3 biến rời bên dưới. Lấy từ Cloudinary Dashboard.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=tripmate

# Firebase Storage (chỉ dùng nếu KHÔNG cấu hình Cloudinary; cần gói Blaze)
# Provide ONE of:
#   FIREBASE_SERVICE_ACCOUNT_JSON  → full service-account JSON inlined as a string
#   FIREBASE_SERVICE_ACCOUNT_PATH  → absolute path to service-account.json
#   GOOGLE_APPLICATION_CREDENTIALS → standard Google ADC env (path to JSON)
# AND set the bucket name (REQUIRED to enable Firebase):
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Gemini (mặc định dùng cho AI assistant v1 + RAG v2)
GEMINI_API_KEY=
# Base URL của Gemini API. Để trống = endpoint chính thức Google.
# Đổi sang proxy bên thứ 3 rẻ hơn (PHẢI gồm /v1beta, KHÔNG có dấu / cuối), vd:
# GEMINI_BASE_URL=https://v98store.com/v1beta
GEMINI_BASE_URL=
# Model chat của AI assistant v1 (mặc định gemini-2.0-flash). RAG v2 dùng RAGV2_* riêng.
GEMINI_MODEL=gemini-2.0-flash
# Chỉ áp dụng model 2.5 (thinking model): token suy luận ăn vào maxOutputTokens.
# 0 = tắt thinking (khuyến nghị cho structured output, tránh JSON cắt cụt).
GEMINI_THINKING_BUDGET=0

# AI assistant — LLM provider
# LLM_PROVIDER: gemini (mặc định, cần GEMINI_API_KEY) | local (self-host Qwen) | template (không cần model)
# Qwen được GIỮ LẠI để chạy LUÂN PHIÊN đo hiệu quả: đổi sang 'local' + bỏ comment 3 dòng LLM_* dưới.
LLM_PROVIDER=gemini
# ── Qwen self-host (node-llama-cpp) — chỉ dùng khi LLM_PROVIDER=local ──
# Tải model: npm run model:download
# LLM_MODEL_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
# Số layer offload lên GPU (RTX 2050 4GB ~ để 'max'; đặt 0 nếu chỉ CPU)
# LLM_GPU_LAYERS=max
# Số token tối đa cho mỗi lần sinh
# LLM_MAX_TOKENS=2048

# ── Chatbot RAG v2 (thử nghiệm, độc lập) — đa provider LLM cho embedding + sinh trả lời ──
# RAGV2_LLM_PROVIDER: gemini (mặc định, cần GEMINI_API_KEY) | openai (cần OPENAI_API_KEY).
# ⚠️ ĐỔI provider → số chiều vector embedding khác nhau (Gemini 3072 vs OpenAI 1536)
#    → BẮT BUỘC chạy lại `npm run rag:ingest` để re-embed toàn bộ chunk, nếu không cosine lệch.
RAGV2_LLM_PROVIDER=gemini
# ── OpenAI (chỉ dùng khi RAGV2_LLM_PROVIDER=openai) ──
OPENAI_API_KEY=
# Base URL OpenAI. Để trống = chính thức. Đổi sang proxy tương thích (PHẢI gồm /v1, không / cuối), vd:
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=
# Model embedding & chat của RAG v2. ĐỔI THEO PROVIDER:
#   gemini → RAGV2_EMBEDDING_MODEL=gemini-embedding-001  RAGV2_CHAT_MODEL=gemini-2.0-flash
#   openai → RAGV2_EMBEDDING_MODEL=text-embedding-3-small RAGV2_CHAT_MODEL=gpt-4o-mini
RAGV2_EMBEDDING_MODEL=gemini-embedding-001
RAGV2_CHAT_MODEL=gemini-2.0-flash
# Kiến trúc AGENT (tool-calling): LLM tự điều phối gọi tool (4 retriever DB + tra
# tài liệu vector + dựng lộ trình) theo vòng ReAct. Cần provider hỗ trợ function
# calling (OpenAI + Gemini đều có). true (mặc định) = agent; false = pipeline 7 bước cũ.
RAGV2_AGENT=true
# Trần số vòng ReAct mỗi câu hỏi (chống lặp vô hạn / tốn quota).
RAGV2_AGENT_MAX_STEPS=5
# Số chunk truy hồi mỗi câu hỏi (top-K cuối cùng đưa vào ngữ cảnh)
RAGV2_TOP_K=4
# ── RAG nâng cao (query rewriting + hybrid search + reranking) ──
# Số ứng viên giữ lại sau hybrid search (dense cosine + sparse BM25 → RRF) để rerank.
RAGV2_CANDIDATE_K=12
# Viết lại câu hỏi bằng LLM trước khi truy hồi (true/false). false = câu gốc + bỏ stopword.
RAGV2_QUERY_REWRITE=true
# Rerank ứng viên rồi lọc top-K (true/false). false = giữ thứ tự RRF.
RAGV2_RERANK=true
# Ngưỡng điểm liên quan 0-10 để giữ 1 chunk sau rerank.
RAGV2_RERANK_MIN_SCORE=4
# Cách rerank: cross-encoder (mặc định — model phân loại cặp câu hỏi–đoạn, chạy
# local qua @xenova/transformers) | llm (cách cũ — gọi LLM chấm 0-10, để so sánh).
RAGV2_RERANK_PROVIDER=cross-encoder
# Model cross-encoder (ONNX, đa ngôn ngữ — hỗ trợ tiếng Việt). Tải trước:
#   npm run rerank:download   (cache vào backend/models/transformers/)
RAGV2_RERANK_MODEL=Xenova/bge-reranker-base
# Thư mục cache weight ONNX của cross-encoder.
RAGV2_RERANK_CACHE_DIR=models/transformers
# Dùng bản quantized (nhẹ, nhanh — true) hay full precision (false).
RAGV2_RERANK_QUANTIZED=true
# Số cặp chấm trong 1 lô (RAM ↔ tốc độ).
RAGV2_RERANK_BATCH=8
# Độ dài token tối đa mỗi cặp (query+đoạn).
RAGV2_RERANK_MAX_LEN=512
# Chặn mọi truy cập mạng (chỉ dùng model đã tải sẵn) — true sau khi đã download.
RAGV2_RERANK_OFFLINE=false
# ── Modular RAG: truy hồi đa nguồn từ DB (trips/places/guides/posts) ──
# Bật/tắt truy hồi DB (true/false). Router (trong bước rewrite) chọn nguồn cần tra.
RAGV2_DB_RETRIEVAL=true
# Số thẻ tối đa lấy mỗi nguồn DB.
RAGV2_DB_LIMIT=4
# Giãn cách (ms) giữa các lần gọi embedding khi ingest — tránh 429 rate limit free tier
# (chỉ áp dụng Gemini gọi tuần tự; OpenAI gộp batch nên bỏ qua)
RAGV2_EMBED_GAP_MS=1200
# Số đoạn gộp trong 1 request embedding (chỉ OpenAI — gửi cả mảng input/1 call)
RAGV2_EMBED_BATCH=64
# Số lần retry khi gặp 429/5xx (exponential backoff 2s→32s)
RAGV2_EMBED_RETRIES=5
# Số lần retry cho bước sinh câu trả lời (chat). Hết quota ngày thì dùng fallback trích xuất.
RAGV2_CHAT_RETRIES=2
# Thư mục tài liệu nguồn (mặc định: <gốc dự án>/documemtRAG). Để trống = mặc định.
RAGV2_DOCS_DIR=

# SePay (payment gateway — optional)
# SEPAY_BANK_NAME phải dùng đúng key SePay nhận, ví dụ: MBBank, Vietcombank, BIDV, TPBank...
SEPAY_API_KEY=
SEPAY_BANK_ACCOUNT=0773066731
SEPAY_BANK_NAME=MBBank
SEPAY_ACCOUNT_HOLDER=NGUYEN VAN NGHIA
SEPAY_WEBHOOK_TOKEN=

# Google Maps (FE Embed API)
# (set in root .env files as VITE_GOOGLE_MAPS_API_KEY)
