# Server
PORT=8080
NODE_ENV=development
APP_NAME=TripMate

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=tripmate
DB_SYNCHRONIZE=true
DB_LOGGING=false
# Bật SSL khi dùng Postgres managed trên cloud (Render/Neon/Supabase). Local để false.
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-but-different
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Email / SMTP (xác thực email khi đăng ký)
# Gmail: bật 2FA rồi tạo "App Password" (16 ký tự) tại https://myaccount.google.com/apppasswords
# Để trống cả 3 dòng host/user/pass → mã OTP sẽ in ra console backend (chế độ dev, không gửi mail thật).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Tên người gửi hiển thị (mặc định: TripMate <SMTP_USER>)
SMTP_FROM=TripMate <no-reply@tripmate.local>

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Upload (local fallback when Firebase isn't configured)
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE_MB=10

# Firebase Storage (preferred for image uploads)
# Provide ONE of:
#   FIREBASE_SERVICE_ACCOUNT_JSON  → full service-account JSON inlined as a string
#   FIREBASE_SERVICE_ACCOUNT_PATH  → absolute path to service-account.json
#   GOOGLE_APPLICATION_CREDENTIALS → standard Google ADC env (path to JSON)
# AND set the bucket name (REQUIRED to enable Firebase):
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Gemini (optional — chỉ dùng khi LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# AI assistant — LLM provider
# LLM_PROVIDER: local (self-host node-llama-cpp, mặc định) | gemini | template (không cần model)
LLM_PROVIDER=local
# Đường dẫn file model GGUF (tải bằng: npm run model:download)
LLM_MODEL_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
# Số layer offload lên GPU (RTX 2050 4GB ~ để 'max' để node-llama-cpp tự cân; đặt 0 nếu chỉ CPU)
LLM_GPU_LAYERS=max
# Số token tối đa cho mỗi lần sinh
LLM_MAX_TOKENS=2048

# ── Chatbot RAG v2 (thử nghiệm, độc lập) — dùng Gemini cho embedding + sinh trả lời ──
# Cần GEMINI_API_KEY ở trên. Model embedding & chat của RAG v2:
RAGV2_EMBEDDING_MODEL=gemini-embedding-001
RAGV2_CHAT_MODEL=gemini-2.0-flash
# Số chunk truy hồi mỗi câu hỏi (top-K)
RAGV2_TOP_K=4
# Giãn cách (ms) giữa các lần gọi embedding khi ingest — tránh 429 rate limit free tier
RAGV2_EMBED_GAP_MS=1200
# Số lần retry khi gặp 429/5xx (exponential backoff 2s→32s)
RAGV2_EMBED_RETRIES=5
# Số lần retry cho bước sinh câu trả lời (chat). Hết quota ngày thì dùng fallback trích xuất.
RAGV2_CHAT_RETRIES=2
# Thư mục tài liệu nguồn (mặc định: <gốc dự án>/documemtRAG). Để trống = mặc định.
RAGV2_DOCS_DIR=

# SePay (payment gateway — optional)
# SEPAY_BANK_NAME phải dùng đúng key SePay nhận, ví dụ: MBBank, Vietcombank, BIDV, TPBank...
SEPAY_API_KEY=
SEPAY_BANK_ACCOUNT=0773066731
SEPAY_BANK_NAME=MBBank
SEPAY_ACCOUNT_HOLDER=NGUYEN VAN NGHIA
SEPAY_WEBHOOK_TOKEN=

# Google Maps (FE Embed API)
# (set in root .env files as VITE_GOOGLE_MAPS_API_KEY)
